{
  "name": "karaoke-ai-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop app for KaraokeAI",
  "main": "./dist/main/index.js",
  "author": "OpenAI Codex",
  "scripts": {
    "build:processor": "powershell -ExecutionPolicy Bypass -File ..\\processor\\build_windows_bundle.ps1 -OutputDir .\\resources\\processor",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build:processor && npm run build && electron-builder",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "34.1.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  },
  "build": {
    "appId": "com.karaokeai.app",
    "productName": "KaraokeAI",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/processor",
        "to": "processor",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
